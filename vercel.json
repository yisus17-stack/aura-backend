{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "index.js": {
      "maxDuration": 15,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/images/(.*)",
      "headers": { "cache-control": "public, max-age=86400" },
      "continue": true
    },
    {
      "src": "/api/(.*)",
      "dest": "index.js"
    },
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ]
}