{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 15,
      "memory": 1024
    },
    "index.js": {
      "maxDuration": 15,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/index.js"
    },
    {
      "source": "/images/(.*)",
      "destination": "/images/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.js"
    }
  ]
}